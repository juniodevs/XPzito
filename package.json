{
  "name": "xpzito",
  "version": "0.1.0",
  "private": true,
  "description": "Cronômetro configurável e bot animado com áudio",
  "workspaces": [
    "api",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm:dev --workspace api\" \"npm:dev --workspace web\"",
    "build": "npm run build --workspace api && npm run build --workspace web",
    "lint": "npm run lint --workspaces",
    "format": "npm run format --workspaces",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "ffmpeg-static": "^5.3.0",
    "patch-package": "^8.0.1",
    "pkg": "^5.8.1",
    "prettier": "^3.6.2"
  }
}
